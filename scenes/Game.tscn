[gd_scene load_steps=2 format=3 uid="uid://game_main"]

[ext_resource type="Script" path="res://scripts/Game.gd" id="1"]

[node name="Game" type="Node2D"]
script = ExtResource("1")

[node name="UI" type="CanvasLayer" parent="."]

[node name="ScoreLabel" type="Label" parent="UI"]
position = Vector2(10, 8)
size = Vector2(180, 36)
text = "Score: 0"
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.0, 0.94, 1.0, 1.0)

[node name="LivesLabel" type="Label" parent="UI"]
position = Vector2(240, 8)
size = Vector2(160, 36)
text = "<3 <3 <3"
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(1.0, 0.4, 0.5, 1.0)

[node name="ComboLabel" type="Label" parent="UI"]
position = Vector2(80, 52)
size = Vector2(240, 36)
visible = false
text = "COMBO x3"
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.84, 0.0, 1.0)
horizontal_alignment = 1

[node name="Overlay" type="ColorRect" parent="."]
anchors_preset = 15
offset_right = 400.0
offset_bottom = 600.0
color = Color(0.0, 0.0, 0.0, 0.82)

[node name="Title" type="Label" parent="Overlay"]
position = Vector2(20, 140)
size = Vector2(360, 140)
text = "It's Raining\nCats & Dogs!"
theme_override_font_sizes/font_size = 34
theme_override_colors/font_color = Color(0.0, 0.94, 1.0, 1.0)
horizontal_alignment = 1

[node name="Sub" type="Label" parent="Overlay"]
position = Vector2(20, 290)
size = Vector2(360, 100)
text = "Catch the animals before\nthey hit the ground!\nMiss 3 = Game Over"
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.85, 0.85, 0.85, 1.0)
horizontal_alignment = 1

[node name="PlayButton" type="Button" parent="Overlay"]
position = Vector2(140, 420)
size = Vector2(120, 48)
text = "PLAY!"
theme_override_font_sizes/font_size = 22

[node name="ComboTimer" type="Timer" parent="."]
wait_time = 1.2
one_shot = true

[connection signal="pressed" from="Overlay/PlayButton" to="." method="_on_play_button_pressed"]
[connection signal="timeout" from="ComboTimer" to="." method="_on_combo_timer_timeout"]
